{
  "name": "bachelor-mess-api",
  "version": "1.0.0",
  "description": "Bachelor Mess Management API with real-time WebSocket (uWebSockets.js). Single process: API + socket start together for minimal memory.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "dev:setup": "node scripts/setup.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "eslint . --max-warnings=0",
    "security-check": "yarn audit",
    "security-fix": "yarn audit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:build": "docker build -t bachelor-mess-api .",
    "docker:run": "docker run -p 3000:3000 bachelor-mess-api",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f",
    "docker:compose:restart": "docker-compose restart",
    "docker:compose:clean": "docker-compose down -v --remove-orphans",
    "health:check": "node healthcheck.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset.js",
    "db:backup": "node scripts/backup.js",
    "db:restore": "node scripts/restore.js",
    "stats:init": "node scripts/init-statistics.js",
    "logs:view": "tail -f logs/app.log",
    "logs:clear": "rm -rf logs/*.log",
    "logs:rotate": "node scripts/log-rotate.js",
    "backup:create": "node scripts/backup.js",
    "backup:list": "node scripts/backup-list.js",
    "monitor:start": "node scripts/monitor.js",
    "monitor:status": "node scripts/monitor-status.js",
    "deploy:staging": "yarn test:ci && yarn lint:check && yarn security-check",
    "deploy:production": "yarn deploy:staging && yarn docker:build"
  },
  "keywords": [
    "express",
    "mongodb",
    "jwt",
    "api",
    "mess-management",
    "rest-api",
    "nodejs",
    "typescript",
    "docker",
    "microservices"
  ],
  "author": "Mahbub Alam",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.7.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.23",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cache": "^5.1.2",
    "uWebSockets.js": "https://github.com/uNetworking/uWebSockets.js#v20.58.0",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.0",
    "minimatch": "3.1.2",
    "mongodb-memory-server": "^10.4.3",
    "mongoose": "^9.2.4",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.4"
  },
  "resolutions": {
    "validator": ">=13.15.22",
    "qs": ">=6.14.2",
    "jws": ">=3.2.3",
    "glob": ">=10.5.0",
    "minimatch": "3.1.2",
    "js-yaml": ">=4.1.1",
    "ajv": ">=6.14.0",
    "lodash": ">=4.17.23"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "packageManager": "yarn@1.22.19",
  "config": {
    "apiPort": "3000",
    "wsPort": "3001"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/bachelor-mess-api.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/bachelor-mess-api/issues"
  },
  "homepage": "https://github.com/yourusername/bachelor-mess-api#readme",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
